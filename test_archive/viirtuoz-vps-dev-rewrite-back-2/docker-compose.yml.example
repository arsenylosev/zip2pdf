# Production docker-compose for kubevirt-api-manager
# Copy to docker-compose.yml and customize. Use env.example for variables.
# Use for: docker-compose build && docker push <image>
#
version: "3.9"

services:
  kubevirt-api:
    build:
      context: .
      dockerfile: Dockerfile
    image: harbor.k8s.naint.tech/kubevirt/kv_api_manager:latest
    container_name: kubevirt-api-manager
    restart: unless-stopped
    ports:
      - "8083:8080"   # Nginx + UI
      - "8004:8001"   # kubectl proxy (/k8s API)
    environment:
      SECRET_KEY: ${SECRET_KEY}
      DEBUG: ${DEBUG:-false}
      FRONTEND_STUB_MODE: ${FRONTEND_STUB_MODE:-false}
      DATABASE_URL: ${DATABASE_URL}
      STORAGE_CLASS_NAME: ${STORAGE_CLASS_NAME}
      LOG_LEVEL: ${LOG_LEVEL:-info}
      LLM_SERVICE_URL: ${LLM_SERVICE_URL}
      LLM_CHAT_SHARED_TOKEN: ${LLM_CHAT_SHARED_TOKEN}
      LLM_USER_KEYS_MAX: ${LLM_USER_KEYS_MAX:-10}
      LLM_KEYS_ENCRYPTION_KEY: ${LLM_KEYS_ENCRYPTION_KEY}
      LLM_AUTH_SERVICE_URL: ${LLM_AUTH_SERVICE_URL}
      LLM_AUTH_ADMIN_TOKEN: ${LLM_AUTH_ADMIN_TOKEN}
      LLM_API_KEY: ${LLM_API_KEY}
      LLM_API_URL: ${LLM_API_URL}
      LLM_MODEL: ${LLM_MODEL}
    volumes:
      - ${HOME}/.kube:/root/.kube:ro
      - ./conf/oauth.d:/etc/nginx/oauth.d:ro
    healthcheck:
      test: ["CMD", "curl", "-f", "http://127.0.0.1:8080/ready"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 20s
