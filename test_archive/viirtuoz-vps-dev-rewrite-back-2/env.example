# Example environment variables for kubevirt-api-manager
# Copy to .env and fill in real values. DO NOT commit .env!
# For docker-compose: cp env.example .env
# For Kubernetes: use Secrets or ConfigMap, see kubernetes_example/secrets-example.yaml

# Flask
SECRET_KEY=
DEBUG=

# Auth (demo mode, when DATABASE_URL is not set)
DEMO_USERNAME=
DEMO_PASSWORD=
DEMO_USER_ID=
SESSION_TIMEOUT=

# Database (PostgreSQL). Required for multi-user mode with admin/user roles
DATABASE_URL=

# Bootstrap: create first admin on startup when DB has no users
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Kubernetes
K8S_NAMESPACE_PREFIX=
STORAGE_CLASS_NAME=

# Allowed image domains for VM creation (comma-separated hostnames)
ALLOWED_IMAGE_DOMAINS=cloud-images.ubuntu.com,download.fedoraproject.org,cloud.centos.org,download.rockylinux.org,cdimage.debian.org,cloud.debian.org,download.opensuse.org

# VM scheduling: CDI importer pods (importer-prime-*) only on nodes with CSI
# JSON nodeSelector so the importer that creates/copies disks runs on nodes with the CSI driver (e.g. Ceph RBD).
# VMs themselves stay on KubeVirt nodes only. Example: {"csi-rbd":"ceph"}
VM_STORAGE_NODE_SELECTOR=
# Optional affinity for CDI importer pods (importer-prime-*).
# Use "kubevirt" to reuse kubevirt-node affinity, or provide full JSON affinity object.
VM_STORAGE_NODE_AFFINITY=

# GPU (Linux VM with GPU)
DEFAULT_GPU_RESOURCE=nvidia.com/1080ti
# Comma-separated list of GPU resources that have a separate HDMI audio device in KubeVirt (e.g. 1080 Ti). Do NOT include mdev/vGPU (RTX Pro 6000) — they have no audio.
GPU_RESOURCES_WITH_AUDIO=nvidia.com/1080ti,nvidia.com/3080ti,nvidia.com/3090
# Driver versions for cloud-init install: comma-separated; "auto" = ubuntu-drivers autoinstall, numeric = nvidia-driver-<ver>
NVIDIA_DRIVER_VERSIONS=auto,535,545,550,555
DEFAULT_NVIDIA_DRIVER=535

# VM resource limits (validation when creating VMs)
MAX_CPU_CORES=16
MAX_MEMORY_GB=64
MAX_STORAGE_GB=500
MAX_GPU_COUNT=2

# Custom NVIDIA driver: GPU resources that use custom install (your logic, e.g. Docker). Callback URL and token are set on the VM.
NVIDIA_GPU_RESOURCES_CUSTOM_DRIVER=nvidia.com/<allocated-name-1>,nvidia.com/<allocated-name-2>
NVIDIA_CUSTOM_DRIVER_CALLBACK_PATH=nvidia-custom-driver-installed
NVIDIA_CUSTOM_DRIVER_ANNOTATION_TOKEN_KEY=vm.kubevirt.io/nvidia-custom-driver-token
APP_INTERNAL_BASE_URL=

# VM Configuration
# VM_RUN_STRATEGY: Controls VM behavior on shutdown/reboot AND auto-start on creation
# Options: Manual (recommended - VM created stopped, requires manual start),
#          RerunOnFailure (VM auto-starts, restart on crash only),
#          Always (old - always restart), Halted (stopped)
VM_RUN_STRATEGY=Manual

# Windows VM (installer + golden image)
WINDOWS_ISO_DATAVOLUME=
WINDOWS_ISO_NAMESPACE=
WINDOWS_GOLDEN_IMAGE_NAME=
WINDOWS_GOLDEN_IMAGE_NAMESPACE=
WINDOWS_ISO_STORAGE_GB=
WINDOWS_DEFAULT_CPU=4
WINDOWS_DEFAULT_MEMORY=8
WINDOWS_DEFAULT_STORAGE=60
WINDOWS_MACHINE_TYPE=q35
WINDOWS_DEFAULT_USERNAME=Administrator
VIRTIO_DRIVERS_IMAGE=

# LLM API (legacy: прямое подключение к модели)
LLM_API_URL=
# DEPRECATED: если не задан, автоматически берётся из LLM_CHAT_SHARED_TOKEN
LLM_API_KEY=
LLM_MODEL=

# LLM per-token: llm-service URL. Доступ по SK-токену из сессии (в UI).
LLM_SERVICE_URL=
# Общий токен для вкладки AI-чат (списания пользователю не применяются).
LLM_CHAT_SHARED_TOKEN=
# Лимит ключей на пользователя во вкладке «Ключи».
LLM_USER_KEYS_MAX=10
# Ключ шифрования для хранения API-ключей в БД (длинная случайная строка).
LLM_KEYS_ENCRYPTION_KEY=

# Juniper router (NAT / port forwarding)
JUNIPER_HOST=
JUNIPER_USER=
JUNIPER_SIDECAR_URL=
JUNIPER_EXTERNAL_IP_POOL=

# Network (for policies)
POD_NETWORK_CIDR=
SERVICE_NETWORK_CIDR=
SERVER_NETWORK_CIDRS=

# Stub / dev
FRONTEND_STUB_MODE=
STUB_NODE_IP=
